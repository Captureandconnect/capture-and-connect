---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamBlock from '../components/sections/TeamBlock.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';

const values = [
  {
    title: 'Quality Over Quantity',
    body: 'Every piece of content we create is built to perform. No filler, no throwaway posts.',
  },
  {
    title: 'Results First',
    body: 'Views and likes are nice. Revenue and growth are better. We optimize for what matters.',
  },
  {
    title: 'Always Evolving',
    body: 'Platforms change daily. We stay ahead so your content never falls behind.',
  },
  {
    title: 'Partnership, Not Service',
    body: "We don't work for you. We work with you. Your growth is our growth.",
  },
];
---

<BaseLayout
  title="About"
  description="Capture & Connect was built by Ryan van der Niet, from solo videographer to full-service creative and digital agency for artists, events, and brands. Learn what drives us."
>

  <!-- Page Hero -->
  <section class="pt-40 pb-16 text-center">
    <div class="container mx-auto px-6 md:px-12 max-w-4xl" data-stagger>

      <!-- Label -->
      <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-6">
        About Us
      </p>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-8">
        Behind the lens
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-white/50 leading-relaxed max-w-2xl mx-auto">
        From solo videographer to full-service creative and digital agency.
      </p>

    </div>
  </section>

  <!-- Ryan's Story -->
  <TeamBlock />

  <!-- Values -->
  <section class="py-16 md:py-20 border-t border-white/[0.04]">
    <div class="container mx-auto px-6 md:px-12 max-w-7xl">

      <!-- Section heading -->
      <div class="text-center mb-16" data-animate>
        <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">
          Our Values
        </p>
        <h2 class="text-3xl md:text-4xl font-bold italic tracking-tight text-white">
          What Drives Us
        </h2>
      </div>

      <!-- Value cards grid -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
        data-stagger
      >
        {values.map((value) => (
          <div
            class="flex flex-col gap-4 bg-white/[0.02] border border-white/[0.06] rounded-xl p-8 transition-all duration-300 hover:border-white/[0.14] hover:bg-white/[0.03]"
            data-reveal="fade-up"
          >
            <h3 class="text-lg font-bold italic text-white leading-tight tracking-tight">
              {value.title}
            </h3>
            <p class="text-sm text-white/50 leading-relaxed">
              {value.body}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CtaBlock
    headline="Ready to work together?"
    subtext="Let's create something that moves your brand forward."
    buttonText="Book a Call"
  />

</BaseLayout>
