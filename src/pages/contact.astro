---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Capture & Connect. Ready to grow your brand? Reach out via our form, WhatsApp, Instagram, or email — we respond within 24 hours."
>

  <!-- Page Hero -->
  <section class="pt-40 pb-16 text-center">
    <div class="container mx-auto px-6 md:px-12 max-w-4xl" data-stagger>

      <!-- Label -->
      <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-6">
        Get In Touch
      </p>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-8">
        Let's create something
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-white/50 leading-relaxed max-w-2xl mx-auto">
        Ready to grow your brand? Reach out and let's talk.
      </p>

    </div>
  </section>

  <!-- Two-column layout: Form + Direct contact -->
  <section class="pb-32">
    <div class="container mx-auto px-6 md:px-12 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: Contact Form -->
        <div data-animate>
          <ContactForm />
        </div>

        <!-- Right: Direct contact options -->
        <div class="flex flex-col gap-5" data-stagger>

          <!-- WhatsApp — most prominent -->
          <div class="flex flex-col gap-4 bg-white/[0.03] border border-white/[0.08] rounded-xl p-6">
            <div class="flex items-center gap-4">
              <!-- WhatsApp icon -->
              <div class="w-11 h-11 flex items-center justify-center bg-[#25D366]/10 border border-[#25D366]/20 rounded-lg shrink-0">
                <svg
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="#25D366"
                  aria-hidden="true"
                >
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Message us on WhatsApp</p>
                <p class="text-xs text-white/40 mt-0.5">Get a response within 24 hours</p>
              </div>
            </div>
            <a
              href="https://wa.me/31641011159?text=Hi%2C%20I'm%20interested%20in%20working%20with%20Capture%20%26%20Connect."
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full bg-[#25D366] hover:bg-[#20bc5a] text-black font-bold text-sm uppercase tracking-wide py-3.5 rounded-lg transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
              </svg>
              Open WhatsApp
            </a>
          </div>

          <!-- Instagram -->
          <a
            href="#"
            class="flex items-center gap-4 bg-white/[0.03] border border-white/[0.08] hover:border-white/20 rounded-xl p-6 transition-colors duration-200 group"
          >
            <!-- Instagram icon -->
            <div class="w-11 h-11 flex items-center justify-center bg-white/[0.04] border border-white/[0.08] rounded-lg shrink-0">
              <svg
                class="w-5 h-5 text-white/60 group-hover:text-white/90 transition-colors duration-200"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-white/90 transition-colors duration-200">
                @captureandconnect
              </p>
              <p class="text-xs text-white/40 mt-0.5">Follow us on Instagram</p>
            </div>
            <!-- Arrow -->
            <div class="ml-auto text-white/20 group-hover:text-white/50 transition-colors duration-200">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:hello@captureandconnect.com"
            class="flex items-center gap-4 bg-white/[0.03] border border-white/[0.08] hover:border-white/20 rounded-xl p-6 transition-colors duration-200 group"
          >
            <!-- Email icon -->
            <div class="w-11 h-11 flex items-center justify-center bg-white/[0.04] border border-white/[0.08] rounded-lg shrink-0">
              <svg
                class="w-5 h-5 text-white/60 group-hover:text-white/90 transition-colors duration-200"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-white/90 transition-colors duration-200">
                hello@captureandconnect.com
              </p>
              <p class="text-xs text-white/40 mt-0.5">Drop us an email</p>
            </div>
            <!-- Arrow -->
            <div class="ml-auto text-white/20 group-hover:text-white/50 transition-colors duration-200">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
