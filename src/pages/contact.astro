---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Capture & Connect. Ready to grow your brand? Reach out via our form, Instagram, or email, we respond within 24 hours."
>

  <!-- Page Hero -->
  <section class="pt-40 pb-16 text-center">
    <div class="container mx-auto px-6 md:px-12 max-w-4xl" data-stagger>

      <!-- Label -->
      <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-6">
        Get In Touch
      </p>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-8">
        Let's create something
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-white/50 leading-relaxed max-w-2xl mx-auto">
        Ready to grow your brand? Reach out and let's talk.
      </p>

    </div>
  </section>

  <!-- Two-column layout: Form + Direct contact -->
  <section class="pb-32">
    <div class="container mx-auto px-6 md:px-12 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: Contact Form -->
        <div data-animate>
          <ContactForm />
        </div>

        <!-- Right: Direct contact options -->
        <div class="flex flex-col gap-5" data-stagger>

          <!-- Email — most prominent -->
          <div class="flex flex-col gap-4 bg-white/[0.03] border border-white/[0.08] rounded-xl p-6">
            <div class="flex items-center gap-4">
              <!-- Email icon -->
              <div class="w-11 h-11 flex items-center justify-center bg-white/[0.06] border border-white/[0.10] rounded-lg shrink-0">
                <svg
                  class="w-5 h-5 text-white/70"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect width="20" height="16" x="2" y="4" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-white">Email us</p>
                <p class="text-xs text-white/40 mt-0.5">We respond within 24 hours</p>
              </div>
            </div>
            <a
              href="mailto:info@captureandconnect.nl"
              class="flex items-center justify-center gap-2 w-full bg-white hover:bg-white/90 text-black font-bold text-sm uppercase tracking-wide py-3.5 rounded-lg transition-colors duration-200"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              Send Email
            </a>
          </div>

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/captureandconnect_"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 bg-white/[0.03] border border-white/[0.08] hover:border-white/20 rounded-xl p-6 transition-colors duration-200 group"
          >
            <!-- Instagram icon -->
            <div class="w-11 h-11 flex items-center justify-center bg-white/[0.04] border border-white/[0.08] rounded-lg shrink-0">
              <svg
                class="w-5 h-5 text-white/60 group-hover:text-white/90 transition-colors duration-200"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white group-hover:text-white/90 transition-colors duration-200">
                @captureandconnect_
              </p>
              <p class="text-xs text-white/40 mt-0.5">Follow us on Instagram</p>
            </div>
            <!-- Arrow -->
            <div class="ml-auto text-white/20 group-hover:text-white/50 transition-colors duration-200">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </div>
          </a>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
