---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/ui/StatCard.astro';
import CaseStudyCard from '../components/sections/CaseStudyCard.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { caseStudies, aggregateStats } from '../data/results';
---

<BaseLayout
  title="Results"
  description="Real results from real campaigns. See how Capture & Connect has driven millions of views, viral moments, and measurable growth for artists, events, and brands."
>

  <!-- Page Hero -->
  <section class="pt-40 pb-16 text-center">
    <div class="container mx-auto px-6 md:px-12 max-w-4xl" data-stagger>

      <!-- Label -->
      <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-6">
        Results
      </p>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-8">
        Numbers don't lie
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-white/50 leading-relaxed max-w-2xl mx-auto">
        Real results from real campaigns. No fluff, no inflated metrics.
      </p>

    </div>
  </section>

  <!-- Aggregate Stats -->
  <section class="pb-24 md:pb-32">
    <div class="container mx-auto px-6 md:px-12 max-w-7xl">

      <!-- Divider line -->
      <div class="w-full h-px bg-white/[0.06] mb-16" aria-hidden="true"></div>

      <div class="grid grid-cols-2 lg:grid-cols-5 gap-8 md:gap-12">
        {aggregateStats.map((stat) => (
          <StatCard
            number={stat.value}
            label={stat.label}
          />
        ))}
      </div>

      <!-- Divider line -->
      <div class="w-full h-px bg-white/[0.06] mt-16" aria-hidden="true"></div>

    </div>
  </section>

  <!-- Case Studies -->
  <section class="pb-24 md:pb-32">
    <div class="container mx-auto px-6 md:px-12 max-w-5xl">

      <!-- Section heading -->
      <div class="mb-12" data-animate>
        <p class="text-xs font-semibold tracking-widest uppercase text-white/40 mb-4">
          Case Studies
        </p>
        <h2 class="text-3xl md:text-4xl font-bold italic tracking-tight text-white">
          Behind the numbers
        </h2>
      </div>

      <!-- Case study cards -->
      <div class="flex flex-col gap-8">
        {caseStudies.map((study) => (
          <div data-reveal="fade-up">
            <CaseStudyCard study={study} />
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CtaBlock
    headline="Want results like these?"
    subtext="Let's talk about what we can do for your brand."
    buttonText="Book a Call"
  />

</BaseLayout>
