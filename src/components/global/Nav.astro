---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Results', href: '/results' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-in-out"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a
        href="/"
        class="flex-shrink-0 group"
        aria-label="Capture & Connect — Home"
      >
        <span class="text-white font-black italic tracking-tight text-lg lg:text-xl uppercase leading-none select-none">
          CAPTURE<span class="font-normal">&thinsp;&amp;&thinsp;</span>CONNECT
        </span>
      </a>

      <!-- Desktop nav links -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => {
          const isActive =
            link.href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                'text-sm font-medium tracking-wide transition-colors duration-200',
                isActive
                  ? 'text-white'
                  : 'text-white/60 hover:text-white',
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center">
        <a
          href="mailto:info@captureandconnect.nl"
          class="inline-flex items-center gap-2 bg-white text-black text-sm font-semibold px-5 py-2.5 rounded-full hover:bg-white/90 active:scale-95 transition-all duration-200"
        >
          Get In Touch
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-hamburger"
        class="hamburger lg:hidden relative flex flex-col items-center justify-center w-10 h-10"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="hamburger-line hamburger-line--top"></span>
        <span class="hamburger-line hamburger-line--mid"></span>
        <span class="hamburger-line hamburger-line--bot"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile full-screen overlay menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-black flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <nav class="flex flex-col items-center gap-8" aria-label="Mobile navigation">
    {navLinks.map((link, i) => {
      const isActive =
        link.href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(link.href);
      return (
        <a
          href={link.href}
          class:list={[
            'mobile-nav-link text-3xl font-black italic uppercase tracking-wider transition-colors duration-200 translate-y-4 opacity-0',
            isActive ? 'text-white' : 'text-white/50 hover:text-white',
          ]}
          style={`--delay: ${i * 60}ms`}
        >
          {link.label}
        </a>
      );
    })}

    <a
      href="mailto:info@captureandconnect.nl"
      class="mobile-nav-link mt-4 inline-flex items-center gap-2 bg-white text-black text-lg font-semibold px-8 py-4 rounded-full hover:bg-white/90 transition-all duration-200 translate-y-4 opacity-0"
      style={`--delay: ${navLinks.length * 60}ms`}
    >
      Get In Touch
    </a>
  </nav>
</div>

<style>
  /* Scrolled state — applied via JS */
  header.scrolled {
    background-color: rgb(0 0 0 / 0.9);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgb(255 255 255 / 0.06);
  }

  /* Hamburger lines */
  .hamburger {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #fff;
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    position: absolute;
  }

  .hamburger-line--top {
    transform: translateY(-7px);
  }

  .hamburger-line--mid {
    /* centered by default */
  }

  .hamburger-line--bot {
    width: 16px;
    transform: translateY(7px);
  }

  /* Open state — X shape */
  .hamburger.active .hamburger-line--top {
    transform: rotate(45deg);
  }

  .hamburger.active .hamburger-line--mid {
    opacity: 0;
  }

  .hamburger.active .hamburger-line--bot {
    width: 24px;
    transform: rotate(-45deg);
  }

  /* Mobile link entrance animation */
  #mobile-menu.open .mobile-nav-link {
    animation: slideUp 0.4s ease forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const header = document.getElementById('site-nav') as HTMLElement;
  const hamburger = document.getElementById('nav-hamburger') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

  // Scroll → add background
  const handleScroll = () => {
    if (window.scrollY > 20) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll(); // run on load

  // Hamburger toggle
  let menuOpen = false;

  const openMenu = () => {
    menuOpen = true;
    hamburger.classList.add('active');
    header.classList.add('menu-open');
    mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
    mobileMenu.classList.add('open', 'opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menuOpen = false;
    hamburger.classList.remove('active');
    header.classList.remove('menu-open');
    mobileMenu.classList.add('opacity-0', 'pointer-events-none');
    mobileMenu.classList.remove('open', 'opacity-100');
    mobileMenu.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  hamburger.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  // Close on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });
</script>
