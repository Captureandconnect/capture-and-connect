---
const quickLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Results', href: '/results' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer style="background-color: #0a0a0a;" class="border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-8">

    <!-- Three columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Column 1: Logo + tagline -->
      <div class="flex flex-col gap-4">
        <a href="/" aria-label="Capture & Connect — Home" class="inline-block">
          <span class="text-white font-black italic tracking-tight text-xl uppercase leading-none select-none">
            CAPTURE<span class="font-normal">&thinsp;&amp;&thinsp;</span>CONNECT
          </span>
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          From lens to likes.
        </p>
        <p class="text-white/30 text-xs mt-2 leading-relaxed max-w-xs">
          Premium content creation and social media agency for brands that want to grow.
        </p>
      </div>

      <!-- Column 2: Quick links -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase">
          Quick Links
        </h3>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-3">
            {quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/50 text-sm hover:text-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Connect -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase">
          Connect
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="mailto:info@captureandconnect.nl"
              class="inline-flex items-center gap-2.5 text-white/50 text-sm hover:text-white transition-colors duration-200 group"
            >
              <!-- Email icon -->
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-white/30 group-hover:text-white transition-colors duration-200 flex-shrink-0"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              info@captureandconnect.nl
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/captureandconnect_"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 text-white/50 text-sm hover:text-white transition-colors duration-200 group"
            >
              <!-- Instagram icon -->
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="text-white/30 group-hover:text-white transition-colors duration-200 flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/30 text-xs">
        &copy; {year} Capture &amp; Connect. All rights reserved.
      </p>
      <p class="text-white/20 text-xs">
        Based in the Netherlands
      </p>
    </div>
  </div>
</footer>
