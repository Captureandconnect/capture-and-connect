---
interface Props {
  src: string;
  poster?: string;
  overlay?: boolean;
  class?: string;
}

const {
  src,
  poster,
  overlay = true,
  class: className = '',
} = Astro.props;
---

<div class={['absolute inset-0 w-full h-full overflow-hidden', className].join(' ')}>
  <video
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster={poster}
    aria-hidden="true"
  >
    <source src={src} />
  </video>

  {overlay && (
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 40%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.8) 100%);"
    />
  )}
</div>
