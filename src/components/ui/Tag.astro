---
interface Props {
  label: string;
  active?: boolean;
  class?: string;
}

const {
  label,
  active = false,
  class: className = '',
  ...rest
} = Astro.props;

const baseClasses = 'inline-flex items-center px-3 py-1 text-xs font-medium uppercase tracking-wider border transition-all duration-200 cursor-pointer select-none rounded-full';

const stateClasses = active
  ? 'border-white text-white bg-white/10'
  : 'border-white/20 text-[var(--color-text-muted,rgba(255,255,255,0.5))] hover:border-white/50 hover:text-white/80';
---

<span
  class={[baseClasses, stateClasses, className].join(' ')}
  data-active={active ? 'true' : 'false'}
  {...rest}
>
  {label}
</span>
