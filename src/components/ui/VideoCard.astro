---
interface Props {
  title: string;
  category: string;
  thumbnail: string;
  video?: string;
  stats?: string;
  class?: string;
}

const {
  title,
  category,
  thumbnail,
  video,
  stats,
  class: className = '',
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'content-creation': 'Content Creation',
  'social-media': 'Social Media',
  'growth-strategy': 'Growth Strategy',
  'web-design': 'Web Design',
};
const categoryLabel = categoryLabels[category] ?? category;
---

<div
  class={[
    'group relative overflow-hidden rounded-sm cursor-pointer bg-black aspect-video',
    className,
  ].join(' ')}
  data-lightbox-trigger
  data-title={title}
  data-category={category}
  data-video={video}
  data-thumbnail={thumbnail}
  data-stats={stats}
  data-category-filter={category}
>
  <!-- Thumbnail -->
  <img
    src={thumbnail}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover transition-all duration-500 group-hover:scale-[1.02]"
    loading="lazy"
    decoding="async"
  />

  <!-- Hover video (desktop only) -->
  {video && (
    <video
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100 pointer-events-none"
      muted
      loop
      playsinline
      preload="none"
      data-hover-video
      aria-hidden="true"
    >
      <source src={video} />
    </video>
  )}

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent transition-opacity duration-300 group-hover:from-black/70" />

  <!-- Stats badge -->
  {stats && (
    <div class="absolute top-3 right-3 bg-black/60 backdrop-blur-sm border border-white/10 text-white text-xs font-medium px-2.5 py-1 rounded-full tracking-wide">
      {stats}
    </div>
  )}

  <!-- Category tag -->
  <div class="absolute top-3 left-3">
    <span class="bg-black/50 backdrop-blur-sm border border-white/10 text-white/70 text-xs uppercase tracking-wider px-2.5 py-1 rounded-full font-medium">
      {categoryLabel}
    </span>
  </div>

  <!-- Bottom info -->
  <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
    <h3 class="text-white font-semibold text-sm md:text-base leading-snug line-clamp-2">
      {title}
    </h3>
  </div>

  <!-- Play icon on hover -->
  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
    <div class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 flex items-center justify-center">
      <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M6.3 2.84A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.27l9.344-5.891a1.5 1.5 0 000-2.538L6.3 2.84z" />
      </svg>
    </div>
  </div>
</div>

<script>
  // Video hover behavior — desktop only
  document.querySelectorAll('[data-hover-video]').forEach((videoEl) => {
    const card = videoEl.closest('[data-lightbox-trigger]') as HTMLElement;
    if (!card) return;

    const video = videoEl as HTMLVideoElement;

    const onEnter = () => {
      if (window.matchMedia('(hover: hover)').matches) {
        video.play().catch(() => {});
      }
    };

    const onLeave = () => {
      video.pause();
      video.currentTime = 0;
    };

    card.addEventListener('mouseenter', onEnter);
    card.addEventListener('mouseleave', onLeave);
  });
</script>
