---
// ServicesOverview.astro — Services preview for home page
import { services } from '../../data/services';
---

<section class="py-24 md:py-32 bg-black" aria-labelledby="services-heading">
  <div class="container mx-auto px-6 md:px-12 max-w-7xl">

    <!-- Section header -->
    <div
      class="opacity-0 mb-16 md:mb-20"
      data-reveal="fade-up"
    >
      <span class="text-sm uppercase tracking-[0.25em] text-white/40 font-medium block mb-4">
        Our Services
      </span>
      <h2
        id="services-heading"
        class="text-4xl md:text-6xl font-black italic leading-none tracking-tight text-white"
      >
        What We Do
      </h2>
    </div>

    <!-- Cards grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"
      data-reveal="stagger"
    >
      {services.map((service) => (
        <article
          class="group relative flex flex-col gap-6 bg-[#0a0a0a] border border-white/[0.06] rounded-xl p-8 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:bg-[#0f0f0f]"
        >
          <!-- Icon -->
          <div class="w-12 h-12 flex items-center justify-center bg-white/[0.04] border border-white/[0.08] rounded-lg shrink-0">
            <svg
              class="w-6 h-6 text-white/70"
              viewBox="0 0 24 24"
              fill={['growth-strategy', 'web-design'].includes(service.id) ? 'none' : 'currentColor'}
              stroke={['growth-strategy', 'web-design'].includes(service.id) ? 'currentColor' : 'none'}
              stroke-width={['growth-strategy', 'web-design'].includes(service.id) ? '2' : undefined}
              stroke-linecap={['growth-strategy', 'web-design'].includes(service.id) ? 'round' : undefined}
              stroke-linejoin={['growth-strategy', 'web-design'].includes(service.id) ? 'round' : undefined}
              aria-hidden="true"
            >
              <path d={service.icon} />
            </svg>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-white leading-tight">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-sm text-white/50 leading-relaxed flex-1">
            {service.description}
          </p>

          <!-- Arrow link -->
          <a
            href="/services"
            class="inline-flex items-center gap-2 text-sm font-medium text-white/50 hover:text-white transition-colors duration-200 group/link mt-auto pt-2 border-t border-white/[0.06] w-full"
            aria-label={`Learn more about ${service.title}`}
          >
            <span>Learn more</span>
            <svg
              class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-1"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div
      class="opacity-0 mt-12 flex justify-center"
      data-reveal="fade-up"
    >
      <a
        href="/services"
        class="inline-flex items-center gap-2 text-sm uppercase tracking-wider text-white/40 hover:text-white transition-colors duration-200 font-medium group/cta"
      >
        View all services
        <svg
          class="w-4 h-4 transition-transform duration-200 group-hover/cta:translate-x-1"
          viewBox="0 0 16 16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

  </div>
</section>
