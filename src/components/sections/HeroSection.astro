---
// HeroSection.astro — Full-viewport hero for home page
// Replace the dark gradient background with:
// <VideoBackground src="/videos/hero.mp4" poster="/images/hero-poster.jpg" /> once video is ready

const WHATSAPP_URL =
  'https://wa.me/31641011159?text=Hi%2C%20I\'m%20interested%20in%20working%20with%20Capture%20%26%20Connect.';
---

<section
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-black"
  aria-label="Hero"
>
  <!-- Background: Replace with VideoBackground component and actual video -->
  <div
    class="absolute inset-0 w-full h-full"
    aria-hidden="true"
  >
    <!-- Placeholder gradient until video is added -->
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255,255,255,0.04) 0%, transparent 70%), linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.3) 60%, rgba(0,0,0,0.95) 100%), #000;"
    ></div>
    <!-- Subtle noise/grain texture overlay -->
    <div
      class="absolute inset-0 opacity-[0.03] mix-blend-overlay pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox%3D%220 0 256 256%22 xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cfilter id%3D%22noise%22%3E%3CfeTurbulence type%3D%22fractalNoise%22 baseFrequency%3D%220.9%22 numOctaves%3D%224%22 stitchTiles%3D%22stitch%22%2F%3E%3C%2Ffilter%3E%3Crect width%3D%22100%25%22 height%3D%22100%25%22 filter%3D%22url(%23noise)%22%2F%3E%3C%2Fsvg%3E');"
    ></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 container mx-auto px-6 md:px-12 flex flex-col items-center text-center max-w-6xl">

    <!-- Label above headline -->
    <div
      class="opacity-0 mb-6 md:mb-8"
      data-reveal="fade-up"
      data-delay="0"
    >
      <span class="text-sm uppercase tracking-[0.25em] text-white/50 font-medium">
        Content Creation &amp; Social Media Agency
      </span>
    </div>

    <!-- H1 headline -->
    <h1
      class="opacity-0 text-5xl md:text-7xl lg:text-8xl font-black italic leading-[0.9] tracking-tight text-white mb-6 md:mb-8"
      data-reveal="fade-up"
      data-delay="100"
    >
      We Create Content<br />
      <span class="text-white/90">That Grows</span><br />
      Your Brand
    </h1>

    <!-- Subline -->
    <p
      class="opacity-0 text-lg md:text-xl text-white/50 max-w-2xl leading-relaxed mb-10 md:mb-12"
      data-reveal="fade-up"
      data-delay="200"
    >
      Event coverage, cinematic visuals and social media management for artists, festivals and brands ready to scale.
    </p>

    <!-- CTA Buttons -->
    <div
      class="opacity-0 flex flex-col sm:flex-row items-center gap-4"
      data-reveal="fade-up"
      data-delay="300"
    >
      <!-- Primary: Book a Call -->
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-black font-semibold text-base tracking-widest uppercase transition-all duration-300 hover:bg-white/90 hover:scale-[1.02] active:bg-white/80 rounded-none select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
      >
        <!-- WhatsApp icon -->
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        Book a Call
      </a>

      <!-- Secondary: View Our Work -->
      <a
        href="/portfolio"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent text-white border border-white/40 font-semibold text-base tracking-wide transition-all duration-300 hover:bg-white hover:text-black hover:border-white hover:scale-[1.02] active:bg-white/90 rounded-none select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
      >
        View Our Work
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 10h12M12 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 animate-scroll-hint"
    data-reveal="fade-in"
    data-delay="600"
    aria-hidden="true"
  >
    <span class="text-xs uppercase tracking-[0.2em] text-white/30 font-medium">Scroll</span>
    <div class="scroll-chevron">
      <svg class="w-5 h-5 text-white/30" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </div>
</section>

<style>
  .scroll-chevron {
    animation: bounce-down 2s ease-in-out infinite;
  }

  @keyframes bounce-down {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.3;
    }
    50% {
      transform: translateY(6px);
      opacity: 0.7;
    }
  }
</style>
