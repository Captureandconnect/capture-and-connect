---
const WA_LINK =
  "https://wa.me/31641011159?text=Hi%2C%20I'm%20interested%20in%20working%20with%20Capture%20%26%20Connect.";

interface Props {
  headline?: string;
  subtext?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryLinkText?: string;
  secondaryLinkHref?: string;
}

const {
  headline = 'Ready to go viral?',
  subtext = "Let's create content that grows your brand.",
  buttonText = 'Book a Call',
  buttonHref = WA_LINK,
  secondaryLinkText,
  secondaryLinkHref,
} = Astro.props;

const isExternal =
  buttonHref.startsWith('http://') || buttonHref.startsWith('https://');
---

<section
  class="relative w-full overflow-hidden py-24 lg:py-32"
  style="background-color: #0d0d0d;"
  data-animate
>
  <!-- Subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 60% at 50% 60%, rgb(255 255 255 / 0.04) 0%, transparent 70%);"
  ></div>

  <!-- Top border line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-white/10" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">

    <!-- Eyebrow label -->
    <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-5">
      Let's work together
    </p>

    <!-- Main headline -->
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-6">
      {headline}
    </h2>

    <!-- Subtext -->
    <p class="text-white/60 text-base sm:text-lg leading-relaxed max-w-xl mx-auto mb-10">
      {subtext}
    </p>

    <!-- CTA button -->
    <div class="flex flex-col items-center gap-4">
      <a
        href={buttonHref}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener noreferrer' : undefined}
        class="inline-flex items-center gap-2.5 bg-white text-black text-base font-semibold px-8 py-4 rounded-full hover:bg-white/90 active:scale-95 transition-all duration-200 shadow-lg shadow-white/10"
      >
        <!-- WhatsApp icon for default CTA -->
        {isExternal && buttonHref.includes('wa.me') && (
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            class="flex-shrink-0"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            />
          </svg>
        )}
        {buttonText}
      </a>

      <!-- Optional secondary link -->
      {secondaryLinkText && secondaryLinkHref && (
        <a
          href={secondaryLinkHref}
          class="text-white/40 text-sm hover:text-white/70 transition-colors duration-200 underline underline-offset-4"
        >
          {secondaryLinkText}
        </a>
      )}
    </div>

  </div>
</section>
