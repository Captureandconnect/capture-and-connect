---
interface Props {
  headline?: string;
  subtext?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryLinkText?: string;
  secondaryLinkHref?: string;
}

const {
  headline = 'Ready to go viral?',
  subtext = "Let's create content that grows your brand.",
  buttonText = 'Get In Touch',
  buttonHref = 'mailto:info@captureandconnect.nl',
  secondaryLinkText,
  secondaryLinkHref,
} = Astro.props;

const isExternal =
  buttonHref.startsWith('http://') || buttonHref.startsWith('https://');
const isMailto = buttonHref.startsWith('mailto:');
---

<section
  class="relative w-full overflow-hidden py-16 lg:py-20"
  style="background-color: #0d0d0d;"
  data-animate
>
  <!-- Subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 60% at 50% 60%, rgb(255 255 255 / 0.04) 0%, transparent 70%);"
  ></div>

  <!-- Top border line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-white/10" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">

    <!-- Eyebrow label -->
    <p class="text-white/40 text-xs font-semibold tracking-widest uppercase mb-5">
      Let's work together
    </p>

    <!-- Main headline -->
    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black italic uppercase tracking-tight text-white leading-none mb-6">
      {headline}
    </h2>

    <!-- Subtext -->
    <p class="text-white/60 text-base sm:text-lg leading-relaxed max-w-xl mx-auto mb-10">
      {subtext}
    </p>

    <!-- CTA button -->
    <div class="flex flex-col items-center gap-4">
      <a
        href={buttonHref}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener noreferrer' : undefined}
        class="inline-flex items-center gap-2.5 bg-white text-black text-base font-semibold px-8 py-4 rounded-full hover:bg-white/90 active:scale-95 transition-all duration-200 shadow-lg shadow-white/10"
      >
        <!-- Email icon for mailto CTA -->
        {isMailto && (
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="flex-shrink-0"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        )}
        {buttonText}
      </a>

      <!-- Optional secondary link -->
      {secondaryLinkText && secondaryLinkHref && (
        <a
          href={secondaryLinkHref}
          class="text-white/40 text-sm hover:text-white/70 transition-colors duration-200 underline underline-offset-4"
        >
          {secondaryLinkText}
        </a>
      )}
    </div>

  </div>
</section>
