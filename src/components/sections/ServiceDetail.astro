---
// ServiceDetail.astro — Individual service detail block for services page
import type { Service } from '../../data/services';

interface Props {
  service: Service;
  reversed?: boolean;
}

const { service, reversed = false } = Astro.props;

---

<section
  class="py-20 md:py-28 border-b border-white/[0.04]"
  id={service.id}
  aria-labelledby={`service-${service.id}-heading`}
>
  <div class="container mx-auto px-6 md:px-12 max-w-7xl">
    <div
      class={[
        'grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center',
        reversed ? 'md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1' : '',
      ].join(' ')}
    >

      <!-- Text block -->
      <div
        class="opacity-0 flex flex-col gap-8"
        data-reveal={reversed ? 'slide-right' : 'slide-left'}
      >

        <!-- Icon -->
        <div class="w-14 h-14 flex items-center justify-center bg-white/[0.04] border border-white/[0.08] rounded-xl shrink-0">
          <svg
            class="w-7 h-7 text-white/60"
            viewBox="0 0 24 24"
            fill={['growth-strategy', 'web-design'].includes(service.id) ? 'none' : 'currentColor'}
            stroke={['growth-strategy', 'web-design'].includes(service.id) ? 'currentColor' : 'none'}
            stroke-width={['growth-strategy', 'web-design'].includes(service.id) ? '2' : undefined}
            stroke-linecap={['growth-strategy', 'web-design'].includes(service.id) ? 'round' : undefined}
            stroke-linejoin={['growth-strategy', 'web-design'].includes(service.id) ? 'round' : undefined}
            aria-hidden="true"
          >
            <path d={service.icon} />
          </svg>
        </div>

        <!-- Title -->
        <h2
          id={`service-${service.id}-heading`}
          class="text-3xl md:text-4xl font-bold italic leading-tight tracking-tight text-white"
        >
          {service.title}
        </h2>

        <!-- Description -->
        <p class="text-base text-white/50 leading-relaxed">
          {service.description}
        </p>

        <!-- Bullet list -->
        <ul class="flex flex-col gap-3">
          {service.bullets.map((bullet) => (
            <li class="flex items-start gap-3 text-sm text-white/60 leading-relaxed">
              <!-- Checkmark icon -->
              <svg
                class="w-4 h-4 text-white/50 shrink-0 mt-0.5"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M3 8l3.5 3.5L13 4" />
              </svg>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <div class="pt-2">
          <a
            href="mailto:info@captureandconnect.nl"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-semibold text-sm tracking-widest uppercase transition-all duration-300 hover:bg-white/90 hover:scale-[1.02] rounded-none"
          >
            Get Started
            <svg
              class="w-4 h-4"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>

      </div>

      <!-- Visual placeholder -->
      <div
        class="opacity-0 relative"
        data-reveal={reversed ? 'slide-left' : 'slide-right'}
      >
        <div
          class="relative w-full aspect-[4/3] rounded-xl overflow-hidden bg-[#0a0a0a] border border-white/[0.06] flex items-center justify-center"
        >
          <!-- Placeholder content — replace with actual image/video when available -->
          <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-8">
            <div
              class="w-16 h-16 rounded-full border border-white/10 flex items-center justify-center opacity-30"
            >
              <svg
                class="w-7 h-7 text-white"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="M21 15l-5-5L5 21" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <span class="text-xs text-white/20 uppercase tracking-wider text-center">
              {service.title}
            </span>
          </div>

          <!-- Subtle gradient overlay -->
          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(255,255,255,0.02) 0%, transparent 70%);"
          ></div>

          <!-- Corner accents -->
          <div class="absolute top-4 left-4 w-6 h-6 border-t border-l border-white/10"></div>
          <div class="absolute top-4 right-4 w-6 h-6 border-t border-r border-white/10"></div>
          <div class="absolute bottom-4 left-4 w-6 h-6 border-b border-l border-white/10"></div>
          <div class="absolute bottom-4 right-4 w-6 h-6 border-b border-r border-white/10"></div>
        </div>
      </div>

    </div>
  </div>
</section>
