---
// CaseStudyCard.astro — Case study card for results page
import Tag from '../ui/Tag.astro';
import type { CaseStudy } from '../../data/results';

interface Props {
  study: CaseStudy;
}

const { study } = Astro.props;
---

<article
  class="group relative flex flex-col gap-8 bg-[#0a0a0a] border border-white/[0.06] rounded-xl p-8 transition-all duration-300 hover:border-white/20"
  data-reveal="fade-up"
  aria-labelledby={`case-study-${study.id}-heading`}
>

  <!-- Glow effect on hover -->
  <div
    class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
    style="box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12), 0 0 40px rgba(255,255,255,0.03);"
    aria-hidden="true"
  ></div>

  <!-- Top row: category badge -->
  <div class="flex items-start justify-between gap-4">
    <Tag label={study.category} />
  </div>

  <!-- Headline -->
  <h3
    id={`case-study-${study.id}-heading`}
    class="text-2xl font-bold italic leading-tight tracking-tight text-white"
  >
    {study.headline}
  </h3>

  <!-- Three sections: Problem / Approach / Result -->
  <div class="flex flex-col gap-6">

    <!-- Problem -->
    <div class="flex flex-col gap-2">
      <span class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold">
        Problem
      </span>
      <p class="text-sm text-white/55 leading-relaxed">
        {study.problem}
      </p>
    </div>

    <!-- Approach -->
    <div class="flex flex-col gap-2">
      <span class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold">
        Approach
      </span>
      <p class="text-sm text-white/55 leading-relaxed">
        {study.approach}
      </p>
    </div>

    <!-- Result -->
    <div class="flex flex-col gap-2">
      <span class="text-[10px] uppercase tracking-[0.2em] text-white/30 font-semibold">
        Result
      </span>
      <p class="text-sm text-white/70 leading-relaxed font-medium">
        {study.result}
      </p>
    </div>

  </div>

  <!-- Stats row -->
  <div class="flex flex-wrap gap-8 pt-6 border-t border-white/[0.06] mt-auto">
    {study.stats.map((stat) => (
      <div class="flex flex-col gap-1">
        <span class="text-3xl font-black text-white leading-none tracking-tight">
          {stat.value}
        </span>
        <span class="text-[10px] uppercase tracking-[0.2em] text-white/35 font-medium">
          {stat.label}
        </span>
      </div>
    ))}
  </div>

</article>
